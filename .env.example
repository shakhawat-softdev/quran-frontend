# Development environment
# For local backend (development):
# NEXT_PUBLIC_API_URL=http://localhost:3000

# For production backend (Vercel):
NEXT_PUBLIC_API_URL=https://quran-backend-git-main-syedarafatcses-projects.vercel.app

# Vercel deployment protection bypass token
# Required for accessing protected Vercel deployments
# Get this from: Vercel Dashboard → quran-backend project → Settings → Deployment Protection
# Steps:
# 1. Go to Vercel dashboard
# 2. Select quran-backend project
# 3. Go to Settings → Deployment Protection
# 4. Click "Add" to generate a new Protection Bypass for Automation token
# 5. Copy the generated token and paste it here
NEXT_PUBLIC_VERCEL_BYPASS_TOKEN=your_bypass_token_here
